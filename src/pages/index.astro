---
import Layout from '../layouts/Layout.astro';
---

<Layout page="home">
  <div class="not-prose space-y-16">

    <div>
      <p class="text-xs uppercase tracking-widest text-gray-300 mb-4">who is this guy</p>
      <p class="text-gray-500 text-lg leading-relaxed max-w-md">Marketing student exploring front-end development, data analysis & marketing research.</p>
    </div>

    <div>
      <p class="text-xs uppercase tracking-widest text-gray-300 mb-6">my projects</p>
      <a href="https://calmservers.com" target="_blank" class="border border-gray-100 rounded-xl p-5 flex justify-between items-center hover:border-gray-200 transition-colors group">
        <div>
          <p class="text-sm font-medium mb-1">calmservers.com</p>
          <p class="text-xs text-gray-400">Rust game server community</p>
        </div>
        <span class="text-gray-200 group-hover:text-gray-400 transition-colors">↗</span>
      </a>
    </div>

    <div>
      <p class="text-xs uppercase tracking-widest text-gray-300 mb-6">readme</p>
      <div class="divide-y divide-gray-100">
        <a href="/posts/first-post" class="flex justify-between items-baseline py-4 group">
          <span class="text-sm font-medium group-hover:text-gray-400 transition-colors">My First Post</span>
          <span class="text-xs text-gray-300">Jun 2026</span>
        </a>
      </div>
      <a href="/blog" class="text-xs text-gray-300 hover:text-gray-500 transition-colors mt-4 inline-block">all posts →</a>
    </div>

  </div>
</Layout>