---
import Layout from '../layouts/Layout.astro';
---

<Layout page="portfolio">
  <div class="not-prose space-y-16">

    <!-- Education -->
    <div>
      <p class="text-xs uppercase tracking-widest text-gray-300 mb-6">Education</p>
      <div class="flex justify-between items-baseline">
        <div>
          <p class="text-sm font-medium">Anglia Ruskin University London</p>
          <p class="text-sm text-gray-400">Digital Marketing · Year 2</p>
        </div>
        <span class="text-xs text-gray-300">2025 — present</span>
      </div>
      
    </div>

    <!-- Certificates -->
    <div>
      <p class="text-xs uppercase tracking-widest text-gray-300 mb-6">Certificates</p>
      <div class="grid grid-cols-2 gap-4">
        <div class="border border-gray-100 rounded-xl aspect-[4/3] flex items-center justify-center text-xs text-gray-300">
          certificate placeholder
        </div>
        <div class="border border-gray-100 rounded-xl aspect-[4/3] flex items-center justify-center text-xs text-gray-300">
          certificate placeholder
        </div>
      </div>
    </div>

    <!-- Work Experience -->
    <div>
      <p class="text-xs uppercase tracking-widest text-gray-300 mb-6">Work Experience</p>
      <div class="divide-y divide-gray-100">
        <div class="grid grid-cols-3 py-4 text-sm">
          <span class="font-medium">Agency Supervisor</span>
          <span class="text-gray-400">RAM Agency. Hospitality</span>
          <span class="text-gray-300 text-right">2024-2026</span>
        </div>
        <div class="grid grid-cols-3 py-4 text-sm">
          <span class="font-medium">Service Staff</span>
          <span class="text-gray-400">Youngs&Co. Hospitality</span>
          <span class="text-gray-300 text-right">2022-2024</span>
        </div>
        <div class="grid grid-cols-3 py-4 text-sm">
          <span class="font-medium">Solar Installer</span>
          <span class="text-gray-400">Renewable Energy</span>
          <span class="text-gray-300 text-right">2023</span>
        </div>
        <div class="grid grid-cols-3 py-4 text-sm">
          <span class="font-medium">Salesman</span>
          <span class="text-gray-400">Orchid. Sales</span>
          <span class="text-gray-300 text-right">2022</span>
        </div>
        <div class="grid grid-cols-3 py-4 text-sm">
          <span class="font-medium">Salesman</span>
          <span class="text-gray-400">British American Tobacco. Sales</span>
          <span class="text-gray-300 text-right">2020</span>
        </div>
        <div class="grid grid-cols-3 py-4 text-sm">
          <span class="font-medium">Administrator</span>
          <span class="text-gray-400">PlayHub. IT</span>
          <span class="text-gray-300 text-right">2019</span>
        </div>
      </div>
    </div>

  </div>
</Layout>
