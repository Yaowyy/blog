---
import '../styles/global.css';
const { page = 'home' } = Astro.props;

const logos = {
  home: 'andrii.kashevskyi',
  blog: 'andrii.blog',
  portfolio: 'andrii.portfolio',
  contact: 'andrii.contact',
};

const navLinks = {
  home: [
    { href: '/blog', label: 'blog' },
    { href: '/portfolio', label: 'portfolio' },
    { href: '/contact', label: 'contact' },
  ],
  blog: [
    { href: '/', label: 'home' },
    { href: '/portfolio', label: 'portfolio' },
    { href: '/contact', label: 'contact' },
  ],
  portfolio: [
    { href: '/', label: 'home' },
    { href: '/blog', label: 'blog' },
    { href: '/contact', label: 'contact' },
  ],
  contact: [
    { href: '/', label: 'home' },
    { href: '/blog', label: 'blog' },
    { href: '/portfolio', label: 'portfolio' },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Andrii's Blog</title>
    <style>
      @keyframes fadein {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      main {
        animation: fadein 1s ease forwards;
      }
    </style>
  </head>
  <body class="bg-white text-gray-900 font-sans">

    <!-- Navigation -->
    <nav class="border-b border-gray-200 px-4 py-4">
      <div class="max-w-2xl mx-auto flex justify-between items-center">
        <a href="/" class="text-2xl font-bold tracking-tight group">
          <span class="group-hover:hidden">{logos[page]}</span>
          <span class="hidden group-hover:inline">andrii.kashevskyi</span>
        </a>
        <div class="flex gap-6 text-gray-400" style="font-size: 15px;">
          {navLinks[page].map(link => (
          <a href={link.href} class="hover:text-gray-900 transition-colors">{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Page content -->
    <main class="max-w-2xl mx-auto px-4 py-12 prose">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-16 px-4 py-6 text-center text-sm text-gray-400">
      © 2026 Andrii
    </footer>

  </body>
</html>