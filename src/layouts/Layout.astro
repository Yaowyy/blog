---
import '../styles/global.css';
const { page = 'home' } = Astro.props;

const logos = {
  home: 'andrii.kashevskyi',
  blog: 'andrii.blog',
  portfolio: 'andrii.portfolio',
  contact: 'andrii.contact',
  hk: 'andrii.香港',
};

const navLinks = {
  home: [
    { href: '/blog', label: 'blog' },
    { href: '/portfolio', label: 'portfolio' },
    { href: '/contact', label: 'contact' },
    { href: '/hk-planner', label: '香港' },
  ],
  blog: [
    { href: '/', label: 'home' },
    { href: '/portfolio', label: 'portfolio' },
    { href: '/contact', label: 'contact' },
    { href: '/hk-planner', label: '香港' },
  ],
  portfolio: [
    { href: '/', label: 'home' },
    { href: '/blog', label: 'blog' },
    { href: '/contact', label: 'contact' },
    { href: '/hk-planner', label: '香港' },
  ],
  contact: [
    { href: '/', label: 'home' },
    { href: '/blog', label: 'blog' },
    { href: '/portfolio', label: 'portfolio' },
    { href: '/hk-planner', label: '香港' },
  ],
  hk: [
    { href: '/', label: 'home' },
    { href: '/blog', label: 'blog' },
    { href: '/portfolio', label: 'portfolio' },
    { href: '/contact', label: 'contact' },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{logos[page]}</title>
    <style>
      @keyframes fadein {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      main {
        animation: fadein 1s ease forwards;
      }
      
      .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 26px;
        cursor: pointer;
      }
      .toggle-switch input { opacity: 0; width: 0; height: 0; position: absolute; }

      .slider {
        position: absolute;
        inset: 0;
        background: #e5e7eb;
        border-radius: 999px;
        transition: background 0.3s ease;
      }
      .slider::before {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        left: 3px;
        top: 3px;
        background: white;
        border-radius: 50%;
        box-shadow: 0 1px 4px rgba(0,0,0,0.18), 0 0.5px 1px rgba(0,0,0,0.1);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      .toggle-switch input:checked + .slider {
        background: #1a1916;
      }
      .toggle-switch input:checked + .slider::before {
        transform: translateX(18px);
      }
    </style>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    
    <!-- Navigation -->
    <nav class="border-b border-gray-200 px-4 py-4">
      <div class="max-w-2xl mx-auto flex justify-between items-center">
        <a href="/" class="text-2xl font-bold tracking-tight group">
          <span class="group-hover:hidden">{logos[page]}</span>
          <span class="hidden group-hover:inline">andrii.kashevskyi</span>
        </a>
        <div class="flex gap-6 text-gray-400" style="font-size: 15px;">
          {navLinks[page].map(link => (
          <a href={link.href} class="hover:text-gray-900 transition-colors">{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Page content -->
    <main class={page === 'hk' ? 'w-full p-0' : 'max-w-2xl mx-auto px-4 py-12 prose'}>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-16 px-4 py-6 flex items-center justify-center gap-4 text-sm text-gray-400">
      <span>© 2026 Andrii</span>
      <label class="toggle-switch" aria-label="Toggle dark mode">
        <input type="checkbox" id="dark-toggle" />
        <span class="slider"></span>
      </label>
    </footer>

    <script>
      const toggle = document.getElementById('dark-toggle') as HTMLInputElement;
      const saved = localStorage.getItem('theme');

      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        toggle.checked = true;
      }

      toggle.addEventListener('change', () => {
        const isDark = toggle.checked;
        document.documentElement.classList.toggle('dark', isDark);
        document.querySelector('.hk-wrap')?.classList.toggle('dark', isDark);
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
