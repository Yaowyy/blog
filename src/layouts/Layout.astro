---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Andrii's Blog</title>
  </head>
  <body class="bg-white text-gray-900 font-sans">

    <!-- Navigation -->
    <nav class="border-b border-gray-200 px-4 py-4">
      <div class="max-w-2xl mx-auto flex justify-between items-center">
        <a href="/" class="font-bold text-lg">andrii.blog</a>
        <div class="flex gap-6 text-sm text-gray-600">
          <a href="/" class="hover:text-black">Home</a>
          <a href="/about" class="hover:text-black">About</a>
        </div>
      </div>
    </nav>

    <!-- Page content -->
    <main class="max-w-2xl mx-auto px-4 py-12 prose">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-16 px-4 py-6 text-center text-sm text-gray-400">
      © 2026 Andrii
    </footer>

  </body>
</html>